# Env files load in layers: shared .env first, then an overlay chosen by APP_ENV
# (default: dev) -> .env.dev / .env.prod. Overlay values override the base, and
# process env vars override everything.
#
#   .env        -> shared vars (Gmail creds) used by every environment
#   .env.dev    -> local overrides (optional)
#   .env.prod   -> Raspberry Pi overrides (paths outside the repo)

# === .env (shared) — required ===
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_PASSWORD=your-gmail-app-password
GMAIL_FROM_ADDR=Property Web Scraper <your-gmail-address@gmail.com>

# === Optional overrides (put in .env or an overlay) ===

# Logging (LOG_ prefix)
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILENAME=property_scraper.log
LOG_MAX_BYTES=1000000
LOG_BACKUP_COUNT=5

# Storage — in prod set this OUTSIDE the repo so deploys don't delete it.
DB_PATH=./database/rightmove.db
